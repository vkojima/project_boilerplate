# Copiar para .env e preencher. Nunca versionar o .env.

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=outputs/logs_history/app.log

# ── Configuração ───────────────────────────────────────────────────────────
CONFIG_PATH=./configs

# ── Câmera (descomentar conforme hardware usado) ───────────────────────────
# ZED_CAMERA_INDEX=0
# BASLER_SERIAL=12345678

# ── Modbus / CLP ───────────────────────────────────────────────────────────
# MODBUS_HOST=192.168.1.100
# MODBUS_PORT=502
# MODBUS_UNIT_ID=1

# ── API / Web (se aplicável) ───────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000

# ── Credenciais externas (jamais hardcoded no código) ─────────────────────
# DB_URL=postgresql://user:pass@host:5432/db
# S3_BUCKET=nome-do-bucket
